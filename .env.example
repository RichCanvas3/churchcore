##############################
# apps/web (Vercel + local)
##############################
# Base URL for LangSmith Deployments agent (no trailing slash).
LANGGRAPH_DEPLOYMENT_URL=

# Server-side secret used to call /runs/wait.
LANGSMITH_API_KEY=

# Single assistant id (single deployed agent).
LANGGRAPH_ASSISTANT_ID=church_agent

# ChurchCore MCP (for local web to load topics/history)
CHURCHCORE_MCP_URL=
CHURCHCORE_MCP_API_KEY=

# A2A Gateway (Cloudflare Worker or service that owns threads/messages)
# - If using local Worker dev: http://localhost:8788
# - If deployed: https://<your-worker>.workers.dev
A2A_GATEWAY_URL=http://localhost:8788
# Optional auth between web (server) and gateway
A2A_GATEWAY_API_KEY=

##############################
# apps/api (LangSmith Deployment)
##############################
OPENAI_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-5.2
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# Knowledge base
KB_PERSIST_TO_CHURCHCORE=1
KB_INDEX_TTL_SECONDS=300

# MCP governance
MCP_TOOL_NAME_PREFIX=1
# Example: churchcore_churchcore_list_services,churchcore_churchcore_list_events,...
MCP_TOOL_ALLOWLIST=
# MCP tool denylist (optional)
MCP_TOOL_DENYLIST=

# MCP servers config (Streamable HTTP)
# Example:
# MCP_SERVERS_JSON={"churchcore":{"transport":"streamable_http","url":"https://<worker>.workers.dev/mcp","headers":{"x-api-key":"<optional>"}}}
MCP_SERVERS_JSON=

