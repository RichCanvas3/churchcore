ccclass:intent_belief a skos:Concept ; skos:inScheme ccclass:StrategicIntentTypeScheme ; skos:notation "belief" ; skos:prefLabel "Core belief" .

ccclass:StrategicIntentLinkTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Strategic intent link types" .

ccclass:intentlink_supports a skos:Concept ; skos:inScheme ccclass:StrategicIntentLinkTypeScheme ; skos:notation "supports" ; skos:prefLabel "Supports" .
