### Faith traditions / denominations (starter taxonomy; extend per church)

ccclass:FaithTraditionScheme a skos:ConceptScheme ;
  skos:prefLabel "Faith traditions" .

ccclass:tradition_evangelical a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "evangelical" ; skos:prefLabel "Evangelical" .
ccclass:tradition_mainline_protestant a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "mainline_protestant" ; skos:prefLabel "Mainline Protestant" .
ccclass:tradition_reformed a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "reformed" ; skos:prefLabel "Reformed" .
ccclass:tradition_baptist a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "baptist" ; skos:prefLabel "Baptist" .
ccclass:tradition_pentecostal_charismatic a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "pentecostal_charismatic" ; skos:prefLabel "Pentecostal / Charismatic" .
ccclass:tradition_anglican a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "anglican" ; skos:prefLabel "Anglican" .
ccclass:tradition_lutheran a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "lutheran" ; skos:prefLabel "Lutheran" .
ccclass:tradition_methodist a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "methodist" ; skos:prefLabel "Methodist / Wesleyan" .
ccclass:tradition_presbyterian a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "presbyterian" ; skos:prefLabel "Presbyterian" .
ccclass:tradition_anabaptist a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "anabaptist" ; skos:prefLabel "Anabaptist" .
ccclass:tradition_restorationist a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "restorationist" ; skos:prefLabel "Restorationist" .
ccclass:tradition_catholic a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "catholic" ; skos:prefLabel "Catholic" .
ccclass:tradition_eastern_orthodox a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "eastern_orthodox" ; skos:prefLabel "Eastern Orthodox" .
ccclass:tradition_oriental_orthodox a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "oriental_orthodox" ; skos:prefLabel "Oriental Orthodox" .
ccclass:tradition_non_denom a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "non_denom" ; skos:prefLabel "Non-denominational" .
ccclass:tradition_other a skos:Concept ; skos:inScheme ccclass:FaithTraditionScheme ; skos:notation "other" ; skos:prefLabel "Other / unspecified" .

ccclass:DenominationScheme a skos:ConceptScheme ;
  skos:prefLabel "Denominations (examples)" .

ccclass:denom_sbc a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "southern_baptist_convention" ; skos:prefLabel "Southern Baptist Convention" ; skos:broader ccclass:tradition_baptist .
ccclass:denom_abcusa a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "american_baptist_churches_usa" ; skos:prefLabel "American Baptist Churches USA" ; skos:broader ccclass:tradition_baptist .
ccclass:denom_pca a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "presbyterian_church_in_america" ; skos:prefLabel "Presbyterian Church in America (PCA)" ; skos:broader ccclass:tradition_presbyterian .
ccclass:denom_pcusa a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "presbyterian_church_usa" ; skos:prefLabel "Presbyterian Church (USA)" ; skos:broader ccclass:tradition_presbyterian .
ccclass:denom_umc a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "united_methodist_church" ; skos:prefLabel "United Methodist Church" ; skos:broader ccclass:tradition_methodist .
ccclass:denom_nazarene a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "church_of_the_nazarene" ; skos:prefLabel "Church of the Nazarene" ; skos:broader ccclass:tradition_methodist .
ccclass:denom_elca a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "elca" ; skos:prefLabel "Evangelical Lutheran Church in America (ELCA)" ; skos:broader ccclass:tradition_lutheran .
ccclass:denom_lcms a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "lcms" ; skos:prefLabel "Lutheran Church—Missouri Synod (LCMS)" ; skos:broader ccclass:tradition_lutheran .
ccclass:denom_assemblies_of_god a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "assemblies_of_god" ; skos:prefLabel "Assemblies of God" ; skos:broader ccclass:tradition_pentecostal_charismatic .
ccclass:denom_foursquare a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "foursquare" ; skos:prefLabel "Foursquare Church" ; skos:broader ccclass:tradition_pentecostal_charismatic .
ccclass:denom_episcopal a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "episcopal_church" ; skos:prefLabel "The Episcopal Church" ; skos:broader ccclass:tradition_anglican .
ccclass:denom_anglican_church_in_north_america a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "acna" ; skos:prefLabel "Anglican Church in North America (ACNA)" ; skos:broader ccclass:tradition_anglican .
ccclass:denom_roman_catholic a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "roman_catholic" ; skos:prefLabel "Roman Catholic Church" ; skos:broader ccclass:tradition_catholic .
ccclass:denom_greek_orthodox a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "greek_orthodox" ; skos:prefLabel "Greek Orthodox" ; skos:broader ccclass:tradition_eastern_orthodox .
ccclass:denom_oca a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "orthodox_church_in_america" ; skos:prefLabel "Orthodox Church in America (OCA)" ; skos:broader ccclass:tradition_eastern_orthodox .
ccclass:denom_non_denom a skos:Concept ; skos:inScheme ccclass:DenominationScheme ; skos:notation "non_denom" ; skos:prefLabel "Non-denominational" ; skos:broader ccclass:tradition_non_denom .

