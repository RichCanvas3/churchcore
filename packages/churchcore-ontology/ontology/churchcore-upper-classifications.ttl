@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix ccclass: <https://ontology.churchcore.ai/cc/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/class>
  a owl:Ontology ;
  rdfs:label "ChurchCore Upper Ontology (classifications)" ;
  rdfs:comment "Shared classification vocabularies (SKOS) referenced by D1 and knowledge base content. Values mirror enum-like strings used in D1 schema so SQL <-> RDF <-> KB can reference stable concept IRIs." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

### Strategic intent

ccclass:StrategicIntentTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Strategic intent types" .

ccclass:intent_purpose a skos:Concept ; skos:inScheme ccclass:StrategicIntentTypeScheme ; skos:notation "purpose" ; skos:prefLabel "Purpose" .
ccclass:intent_vision a skos:Concept ; skos:inScheme ccclass:StrategicIntentTypeScheme ; skos:notation "vision" ; skos:prefLabel "Vision" .
