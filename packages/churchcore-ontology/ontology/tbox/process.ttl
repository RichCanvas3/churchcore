@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix ccproc: <https://ontology.churchcore.ai/cc/process#> .
@prefix ccplan: <https://ontology.churchcore.ai/cc/plan#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix p-plan: <http://purl.org/net/p-plan#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/process/tbox>
  a owl:Ontology ;
  rdfs:label "ChurchCore T-Box (process)" ;
  rdfs:comment "ProcessRole (specification) vs Process (execution) vocabulary aligned to p-plan and PROV-O, and designed to compose with Step/Activity and State/Manifestation." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <https://ontology.churchcore.ai/cc/plan/tbox> ;
  owl:imports <https://ontology.churchcore.ai/cc/state/tbox> ;
  owl:imports <http://purl.org/net/p-plan> ;
  owl:imports <http://www.w3.org/ns/prov-o-20130430> .

ccproc:ProcessRole a owl:Class ;
  rdfs:label "ProcessRole" ;
  rdfs:comment "Specification of a process: a Plan that bundles Steps and relevant State categories (preconditions/effects). Use ccplan:Plan for generic plans; use ccproc:ProcessRole when you want a process-oriented plan with explicit step/state semantics." ;
  rdfs:subClassOf ccplan:Plan .

ccproc:Process a owl:Class ;
  rdfs:label "Process" ;
  rdfs:comment "Execution of a process: a PROV bundle that groups Activities and their produced/used Entities (including Manifestations) as a coherent run." ;
  rdfs:subClassOf prov:Bundle .

ccproc:correspondsToProcessRole a owl:ObjectProperty ;
  rdfs:label "correspondsToProcessRole" ;
  rdfs:comment "Links a Process execution (bundle) to its ProcessRole specification (plan)." ;
  rdfs:domain ccproc:Process ;
  rdfs:range ccproc:ProcessRole .

ccproc:hasStep a owl:ObjectProperty ;
  rdfs:label "hasStep" ;
  rdfs:comment "Convenience: links a ProcessRole to a member Step (specification-side step-type). Equivalent information can be expressed using p-plan:hasStep." ;
  rdfs:domain ccproc:ProcessRole ;
  rdfs:range cc:Step ;
  rdfs:subPropertyOf p-plan:hasStep .

ccproc:hasRequiredState a owl:ObjectProperty ;
  rdfs:label "hasRequiredState" ;
  rdfs:comment "A State category that must hold (typically via a Manifestation) for this ProcessRole to proceed." ;
  rdfs:domain ccproc:ProcessRole ;
  rdfs:range cc:State .

ccproc:hasTargetState a owl:ObjectProperty ;
  rdfs:label "hasTargetState" ;
  rdfs:comment "A State category representing the intended terminal outcome of this ProcessRole." ;
  rdfs:domain ccproc:ProcessRole ;
  rdfs:range cc:State .

ccproc:hasPreconditionState a owl:ObjectProperty ;
  rdfs:label "hasPreconditionState" ;
  rdfs:comment "Specification-side: a State category that should hold (typically on a Manifestation) before executing an Activity that corresponds to this Step." ;
  rdfs:domain cc:Step ;
  rdfs:range cc:State .

ccproc:hasEffectState a owl:ObjectProperty ;
  rdfs:label "hasEffectState" ;
  rdfs:comment "Specification-side: a State category that should hold (typically on a Manifestation) as an intended outcome of executing an Activity that corresponds to this Step." ;
  rdfs:domain cc:Step ;
  rdfs:range cc:State .

ccproc:hasActivity a owl:ObjectProperty ;
  rdfs:label "hasActivity" ;
  rdfs:comment "Convenience: links a Process bundle to an included Activity occurrence." ;
  rdfs:domain ccproc:Process ;
  rdfs:range prov:Activity .

ccproc:inProcess a owl:ObjectProperty ;
  rdfs:label "inProcess" ;
  rdfs:comment "Inverse convenience: links an Activity occurrence to the Process bundle that contains it." ;
  rdfs:domain prov:Activity ;
  rdfs:range ccproc:Process ;
  owl:inverseOf ccproc:hasActivity .

ccproc:hasManifestation a owl:ObjectProperty ;
  rdfs:label "hasManifestation" ;
  rdfs:comment "Convenience: links a Process bundle to an included Manifestation snapshot." ;
  rdfs:domain ccproc:Process ;
  rdfs:range cc:Manifestation .

ccproc:manifestationInProcess a owl:ObjectProperty ;
  rdfs:label "manifestationInProcess" ;
  rdfs:comment "Inverse convenience: links a Manifestation snapshot to the Process bundle that contains it." ;
  rdfs:domain cc:Manifestation ;
  rdfs:range ccproc:Process ;
  owl:inverseOf ccproc:hasManifestation .

ccproc:usedManifestation a owl:ObjectProperty ;
  rdfs:label "usedManifestation" ;
  rdfs:comment "Execution-side: links an Activity to an input Manifestation snapshot it used. This is a typed convenience for provenance, aligned to prov:used." ;
  rdfs:domain cc:Activity ;
  rdfs:range cc:Manifestation ;
  rdfs:subPropertyOf prov:used .

ccproc:generatedManifestation a owl:ObjectProperty ;
  rdfs:label "generatedManifestation" ;
  rdfs:comment "Execution-side: links an Activity to an output Manifestation snapshot it generated. This is a typed convenience for provenance, aligned to prov:generated." ;
  rdfs:domain cc:Activity ;
  rdfs:range cc:Manifestation ;
  rdfs:subPropertyOf prov:generated .
