@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix cccomm: <https://ontology.churchcore.ai/cc/community#> .
@prefix ccsit: <https://ontology.churchcore.ai/cc/situation#> .
@prefix at: <https://agentictrust.io/ontology/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ontology.churchcore.ai/cc/community/tbox>
  a owl:Ontology ;
  rdfs:label "ChurchCore T-Box (community)" ;
  rdfs:comment "Faith-neutral group/membership schema. Local church group specializations belong in ChurchCore-Congregation." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <https://ontology.churchcore.ai/cc/situation> ;
  owl:imports <https://agentictrust.io/ontology/core/trust> ;
  owl:imports <http://www.w3.org/ns/prov-o-20130430> .

cccomm:Group a owl:Class ;
  rdfs:label "Group" ;
  rdfs:comment "A group is modeled as an Organization (Agent) so it can participate in membership situations." ;
  rdfs:subClassOf cc:Organization .

cccomm:GroupMembershipSituation a owl:Class ;
  rdfs:label "GroupMembershipSituation" ;
  rdfs:comment "Reified membership context (DnS-style). Use qualifiedSituationParticipation to state who participates and in what role." ;
  rdfs:subClassOf ccsit:MembershipSituation .

cccomm:MemberRole a owl:Class ;
  rdfs:label "MemberRole" ;
  rdfs:subClassOf at:Role .

cccomm:HostRole a owl:Class ;
  rdfs:label "HostRole" ;
  rdfs:subClassOf at:Role .

cccomm:LeaderRole a owl:Class ;
  rdfs:label "LeaderRole" ;
  rdfs:subClassOf at:Role .

cccomm:StaffRole a owl:Class ;
  rdfs:label "StaffRole" ;
  rdfs:subClassOf at:Role .

cccomm:membershipPerson a owl:ObjectProperty ;
  rdfs:label "membershipPerson" ;
  rdfs:comment "Convenience link to the person this membership is about." ;
  rdfs:domain cccomm:GroupMembershipSituation ;
  rdfs:range cc:Person ;
  rdfs:subPropertyOf at:isAboutAgent .

cccomm:membershipGroup a owl:ObjectProperty ;
  rdfs:label "membershipGroup" ;
  rdfs:comment "Convenience link to the group this membership is about." ;
  rdfs:domain cccomm:GroupMembershipSituation ;
  rdfs:range cccomm:Group ;
  rdfs:subPropertyOf at:isAboutAgent .

cccomm:membershipStatus a owl:DatatypeProperty ;
  rdfs:label "membershipStatus" ;
  rdfs:comment "Implementation-friendly status string (e.g. active, invited, inactive)." ;
  rdfs:domain cccomm:GroupMembershipSituation ;
  rdfs:range xsd:string .

