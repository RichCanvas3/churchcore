@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/all>
  a owl:Ontology ;
  rdfs:label "ChurchCore Upper Ontology (all)" ;
  owl:imports
    <https://ontology.churchcore.ai/cc>,
    <https://ontology.churchcore.ai/cc/plan>,
    <https://ontology.churchcore.ai/cc/prov>,
    <https://ontology.churchcore.ai/cc/class>,
    <https://ontology.churchcore.ai/cc/situation>,
    <https://ontology.churchcore.ai/cc/state>,
    <https://ontology.churchcore.ai/cc/process>,
    <https://ontology.churchcore.ai/cc/intent>,
    <https://ontology.churchcore.ai/cc/community>,
    <https://ontology.churchcore.ai/cc/journey>,
    <https://ontology.churchcore.ai/cc/commerce> .

