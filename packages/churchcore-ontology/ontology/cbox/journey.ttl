@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix ccclass: <https://ontology.churchcore.ai/cc/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/cbox/journey>
  a owl:Ontology ;
  rdfs:label "ChurchCore C-Box (journey)" ;
  rdfs:comment "Controlled vocabularies for journey graphs, nodes, edges, and per-person journey events." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

ccclass:JourneyNodeTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Journey node types" .

ccclass:journey_node_Stage a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Stage" ; skos:prefLabel "Stage" .
ccclass:journey_node_Milestone a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Milestone" ; skos:prefLabel "Milestone" .
ccclass:journey_node_Practice a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Practice" ; skos:prefLabel "Practice" .
ccclass:journey_node_DoctrineTopic a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "DoctrineTopic" ; skos:prefLabel "Doctrine topic" .
ccclass:journey_node_Barrier a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Barrier" ; skos:prefLabel "Barrier" .
ccclass:journey_node_Resource a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Resource" ; skos:prefLabel "Resource" .
ccclass:journey_node_Community a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Community" ; skos:prefLabel "Community" .
ccclass:journey_node_Assessment a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "Assessment" ; skos:prefLabel "Assessment" .
ccclass:journey_node_ActionStep a skos:Concept ; skos:inScheme ccclass:JourneyNodeTypeScheme ; skos:notation "ActionStep" ; skos:prefLabel "Action step" .

ccclass:JourneyEdgeTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Journey edge types" .

ccclass:journey_edge_NEXT_STAGE a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "NEXT_STAGE" ; skos:prefLabel "Next stage" .
ccclass:journey_edge_REQUIRES a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "REQUIRES" ; skos:prefLabel "Requires" .
ccclass:journey_edge_RECOMMENDS a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "RECOMMENDS" ; skos:prefLabel "Recommends" .
ccclass:journey_edge_UNLOCKS a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "UNLOCKS" ; skos:prefLabel "Unlocks" .
ccclass:journey_edge_BLOCKED_BY a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "BLOCKED_BY" ; skos:prefLabel "Blocked by" .
ccclass:journey_edge_RESOLVED_BY a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "RESOLVED_BY" ; skos:prefLabel "Resolved by" .
ccclass:journey_edge_SUPPORTED_BY a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "SUPPORTED_BY" ; skos:prefLabel "Supported by" .
ccclass:journey_edge_MEASURED_BY a skos:Concept ; skos:inScheme ccclass:JourneyEdgeTypeScheme ; skos:notation "MEASURED_BY" ; skos:prefLabel "Measured by" .

ccclass:JourneyEventTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Journey event types" .

ccclass:journey_event_COMPLETED a skos:Concept ; skos:inScheme ccclass:JourneyEventTypeScheme ; skos:notation "COMPLETED" ; skos:prefLabel "Completed" .
ccclass:journey_event_STARTED a skos:Concept ; skos:inScheme ccclass:JourneyEventTypeScheme ; skos:notation "STARTED" ; skos:prefLabel "Started" .
ccclass:journey_event_STREAK a skos:Concept ; skos:inScheme ccclass:JourneyEventTypeScheme ; skos:notation "STREAK" ; skos:prefLabel "Streak" .
ccclass:journey_event_NOTE a skos:Concept ; skos:inScheme ccclass:JourneyEventTypeScheme ; skos:notation "NOTE" ; skos:prefLabel "Note" .
ccclass:journey_event_ASSESSMENT a skos:Concept ; skos:inScheme ccclass:JourneyEventTypeScheme ; skos:notation "ASSESSMENT" ; skos:prefLabel "Assessment" .

ccclass:JourneyEventSourceScheme a skos:ConceptScheme ;
  skos:prefLabel "Journey event sources" .

ccclass:journey_source_user a skos:Concept ; skos:inScheme ccclass:JourneyEventSourceScheme ; skos:notation "user" ; skos:prefLabel "User" .
ccclass:journey_source_staff a skos:Concept ; skos:inScheme ccclass:JourneyEventSourceScheme ; skos:notation "staff" ; skos:prefLabel "Staff" .
ccclass:journey_source_system a skos:Concept ; skos:inScheme ccclass:JourneyEventSourceScheme ; skos:notation "system" ; skos:prefLabel "System" .
ccclass:journey_source_agent a skos:Concept ; skos:inScheme ccclass:JourneyEventSourceScheme ; skos:notation "agent" ; skos:prefLabel "Agent" .

ccclass:JourneyEventAccessLevelScheme a skos:ConceptScheme ;
  skos:prefLabel "Journey event access levels" .

ccclass:journey_access_self a skos:Concept ; skos:inScheme ccclass:JourneyEventAccessLevelScheme ; skos:notation "self" ; skos:prefLabel "Self" .
ccclass:journey_access_staff a skos:Concept ; skos:inScheme ccclass:JourneyEventAccessLevelScheme ; skos:notation "staff" ; skos:prefLabel "Staff" .
ccclass:journey_access_pastoral a skos:Concept ; skos:inScheme ccclass:JourneyEventAccessLevelScheme ; skos:notation "pastoral" ; skos:prefLabel "Pastoral" .
ccclass:journey_access_restricted a skos:Concept ; skos:inScheme ccclass:JourneyEventAccessLevelScheme ; skos:notation "restricted" ; skos:prefLabel "Restricted" .

ccclass:JourneyEntityTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Journey entity link types" .

ccclass:journey_entity_group a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "group" ; skos:prefLabel "Group" .
ccclass:journey_entity_event a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "event" ; skos:prefLabel "Event" .
ccclass:journey_entity_opportunity a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "opportunity" ; skos:prefLabel "Opportunity" .
ccclass:journey_entity_resource a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "resource" ; skos:prefLabel "Resource" .
ccclass:journey_entity_content_doc a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "content_doc" ; skos:prefLabel "Content doc" .
ccclass:journey_entity_person a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "person" ; skos:prefLabel "Person" .
ccclass:journey_entity_class a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "class" ; skos:prefLabel "Class" .
ccclass:journey_entity_custom a skos:Concept ; skos:inScheme ccclass:JourneyEntityTypeScheme ; skos:notation "custom" ; skos:prefLabel "Custom" .

