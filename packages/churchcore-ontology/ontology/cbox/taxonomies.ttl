ccclass:classificationType_SPIRITUAL_GIFT a skos:Concept ; skos:inScheme ccclass:ClassificationTypeScheme ; skos:notation "SPIRITUAL_GIFT" ; skos:prefLabel "Spiritual gift" .
ccclass:classificationType_ROLE a skos:Concept ; skos:inScheme ccclass:ClassificationTypeScheme ; skos:notation "ROLE" ; skos:prefLabel "Role" .
