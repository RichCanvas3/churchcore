@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/cbox/taxonomies>
  a owl:Ontology ;
  rdfs:label "ChurchCore C-Box (taxonomies)" ;
  rdfs:comment "Shared category schemes used across the KB: organization types, ministry types/focus, topics, service types, event types, geography, language, audience, demographics, and roles." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

### Classification types (mirrors ClassificationTypeEnum)

ccclass:ClassificationTypeScheme a skos:ConceptScheme ;
  skos:prefLabel "Classification types" .

ccclass:classificationType_CHURCH_TYPE a skos:Concept ; skos:inScheme ccclass:ClassificationTypeScheme ; skos:notation "CHURCH_TYPE" ; skos:prefLabel "Church type" .
