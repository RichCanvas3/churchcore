@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix ccclass: <https://ontology.churchcore.ai/cc/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/cbox/classifications>
  a owl:Ontology ;
  rdfs:label "ChurchCore C-Box (classifications)" ;
  rdfs:comment "C-Box index for ChurchCore controlled vocabularies. Concrete schemes live in focused C-Box modules and are imported here so the wrapper IRI stays stable." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> ;
  owl:imports
    <https://ontology.churchcore.ai/cc/cbox/strategic-intent>,
    <https://ontology.churchcore.ai/cc/cbox/journey>,
    <https://ontology.churchcore.ai/cc/cbox/community>,
    <https://ontology.churchcore.ai/cc/cbox/people-relationships>,
    <https://ontology.churchcore.ai/cc/cbox/taxonomies>,
    <https://ontology.churchcore.ai/cc/cbox/ops-statuses>,
    <https://ontology.churchcore.ai/cc/cbox/state-categories>,
    <https://ontology.churchcore.ai/cc/cbox/situations> .

