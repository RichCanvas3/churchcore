ccclass:sender_assistant a skos:Concept ; skos:inScheme ccclass:ChatMessageSenderTypeScheme ; skos:notation "assistant" ; skos:prefLabel "Assistant" .
ccclass:sender_system a skos:Concept ; skos:inScheme ccclass:ChatMessageSenderTypeScheme ; skos:notation "system" ; skos:prefLabel "System" .

