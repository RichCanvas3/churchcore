@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix ccclass: <https://ontology.churchcore.ai/cc/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/cbox/ops-statuses>
  a owl:Ontology ;
  rdfs:label "ChurchCore C-Box (operational statuses)" ;
  rdfs:comment "Controlled vocabularies that mirror operational statuses/types used by apps (enum-like values), kept in the upper C-Box for reuse." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

ccclass:ChatThreadStatusScheme a skos:ConceptScheme ; skos:prefLabel "Chat thread statuses" .
ccclass:thread_status_active a skos:Concept ; skos:inScheme ccclass:ChatThreadStatusScheme ; skos:notation "active" ; skos:prefLabel "Active" .
ccclass:thread_status_archived a skos:Concept ; skos:inScheme ccclass:ChatThreadStatusScheme ; skos:notation "archived" ; skos:prefLabel "Archived" .

ccclass:ChatMessageSenderTypeScheme a skos:ConceptScheme ; skos:prefLabel "Chat message sender types" .
