@prefix ccproc: <https://ontology.churchcore.ai/cc/process#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/process>
  a owl:Ontology ;
