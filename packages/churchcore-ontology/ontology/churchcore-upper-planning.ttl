@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix ccplan: <https://ontology.churchcore.ai/cc/plan#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix p-plan: <http://purl.org/net/p-plan#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ontology.churchcore.ai/cc/plan>
  a owl:Ontology ;
  rdfs:label "ChurchCore Upper Ontology (planning)" ;
  rdfs:comment "Planning layer aligned to EP-PLAN concepts used in RichCanvas principles (as-planned flows)." ;
  owl:imports <https://ontology.churchcore.ai/cc> ;
  owl:imports <http://purl.org/net/p-plan> .

ccplan:Plan a owl:Class ;
  rdfs:label "Plan" ;
  rdfs:subClassOf p-plan:Plan .

ccplan:Step a owl:Class ;
  rdfs:label "Step" ;
  rdfs:subClassOf p-plan:Step .

ccplan:Variable a owl:Class ;
  rdfs:label "Variable" ;
  rdfs:subClassOf p-plan:Variable .

ccplan:hasPlannedStep a owl:ObjectProperty ;
  rdfs:label "hasPlannedStep" ;
  rdfs:domain ccplan:Plan ;
  rdfs:range ccplan:Step ;
  rdfs:subPropertyOf p-plan:hasStep .

ccplan:isStepOfPlan a owl:ObjectProperty ;
  rdfs:label "isStepOfPlan" ;
  rdfs:domain ccplan:Step ;
  rdfs:range ccplan:Plan ;
  rdfs:subPropertyOf p-plan:isStepOfPlan .

ccplan:scheduledAt a owl:DatatypeProperty ;
  rdfs:label "scheduledAt" ;
  rdfs:domain ccplan:Step ;
  rdfs:range xsd:dateTime .

ccplan:correspondsToActivityRole a owl:ObjectProperty ;
  rdfs:label "correspondsToActivityRole" ;
  rdfs:domain ccplan:Step ;
  rdfs:range cc:ActivityRole .

