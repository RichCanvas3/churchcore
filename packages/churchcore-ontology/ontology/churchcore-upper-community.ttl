@prefix cc: <https://ontology.churchcore.ai/cc#> .
@prefix cccomm: <https://ontology.churchcore.ai/cc/community#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/community>
  a owl:Ontology ;
  rdfs:label "ChurchCore Upper Ontology (community)" ;
  rdfs:comment "Community module wrapper (imports T-Box/C-Box artifacts). Local church group specializations live in ChurchCore-Congregation." ;
  owl:imports <https://ontology.churchcore.ai/cc/community/tbox> .

