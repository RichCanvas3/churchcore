@prefix cccongclass: <https://ontology.churchcore.ai/cc/congregation/class#> .
@prefix ccclass: <https://ontology.churchcore.ai/cc/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/congregation/cbox/audience-segments>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Congregation C-Box (audience segments)" ;
  rdfs:comment "Congregation-local audience/segment categories for programs, communications, and services. This module EXTENDS the canonical audience scheme in the upper ontology (ccclass:AudienceScheme) without defining a competing scheme." ;
  owl:imports <http://www.w3.org/2004/02/skos/core> ;
  owl:imports <https://ontology.churchcore.ai/cc/cbox/taxonomies> .

# Congregation-facing segments (starter set)
cccongclass:audience_new_here a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "new_here" ;
  skos:prefLabel "New here" .

cccongclass:audience_seekers a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "seekers" ;
  skos:prefLabel "Seekers / exploring" .

cccongclass:audience_members a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "members" ;
  skos:prefLabel "Members" .

cccongclass:audience_volunteers a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "volunteers" ;
  skos:prefLabel "Volunteers / serving team" .

