@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/congregation/all>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Congregation Ontology (all)" ;
  rdfs:comment "Master import file for ChurchCore-Congregation (Local-C) modules." ;
  owl:imports
    <https://ontology.churchcore.ai/cc/congregation/tbox/ops>,
    <https://ontology.churchcore.ai/cc/congregation/cbox/ministry-categories>,
    <https://ontology.churchcore.ai/cc/congregation/cbox/service-types>,
    <https://ontology.churchcore.ai/cc/congregation/cbox/attendance-statuses> .

