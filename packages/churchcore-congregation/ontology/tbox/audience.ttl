@prefix cccong: <https://ontology.churchcore.ai/cc/congregation#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/congregation/tbox/audience>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Congregation T-Box (audience)" ;
  rdfs:comment "Audience/segmentation schema for congregation-local targeting (ministry programs, services, communications). Categories live in the Congregation C-Box." ;
  owl:imports <https://ontology.churchcore.ai/cc/all> ;
  owl:imports <https://ontology.churchcore.ai/cc/congregation/tbox/ops> ;
  owl:imports <http://www.w3.org/ns/prov-o-20130430> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

cccong:AudienceSegment a owl:Class ;
  rdfs:label "AudienceSegment" ;
  rdfs:comment "A reusable audience/segment category used for local congregation targeting (SKOS concept).";
  rdfs:subClassOf skos:Concept .

cccong:hasAudienceSegment a owl:ObjectProperty ;
  rdfs:label "hasAudienceSegment" ;
  rdfs:comment "Links an entity (ministry, small group, service, event, resource) to an audience segment category (SKOS concept)." ;
  rdfs:domain prov:Entity ;
  rdfs:range skos:Concept .

cccong:audienceSegmentScheme a owl:ObjectProperty ;
  rdfs:label "audienceSegmentScheme" ;
  rdfs:comment "Links an audience segment concept to its scheme (typically ccclass:AudienceScheme in the upper ontology)." ;
  rdfs:domain skos:Concept ;
  rdfs:range skos:ConceptScheme .

