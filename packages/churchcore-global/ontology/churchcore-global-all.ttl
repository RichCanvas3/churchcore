@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/global/all>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Global Ontology (all)" ;
  rdfs:comment "Master import file for ChurchCore-Global (Big-C) modules." ;
