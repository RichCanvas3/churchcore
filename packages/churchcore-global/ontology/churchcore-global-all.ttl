    <https://ontology.churchcore.ai/cc/global/cbox/denominations>,
    <https://ontology.churchcore.ai/cc/global/cbox/traditions>,
    <https://ontology.churchcore.ai/cc/global/cbox/theology>,
    <https://ontology.churchcore.ai/cc/global/cbox/initiative-types>,
    <https://ontology.churchcore.ai/cc/global/cbox/people-group-status>,
    <https://ontology.churchcore.ai/cc/global/cbox/organization-service-categories>,
    <https://ontology.churchcore.ai/cc/global/cbox/partnership-types>,
    <https://ontology.churchcore.ai/cc/global/cbox/audience-segments>,
    <https://ontology.churchcore.ai/cc/global/cbox/flourishing-dimensions>,
    <https://ontology.churchcore.ai/cc/global/cbox/congregation-thriving-dimensions> .

