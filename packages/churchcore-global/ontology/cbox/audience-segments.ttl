@prefix ccgclass: <https://ontology.churchcore.ai/cc/global/class#> .
@prefix ccclass: <https://ontology.churchcore.ai/cc/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/global/cbox/audience-segments>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Global C-Box (audience segments)" ;
  rdfs:comment "Ecosystem-scale audience/segment categories for discovery, benchmarking, and targeting. This module EXTENDS the canonical audience scheme in the upper ontology (ccclass:AudienceScheme) without defining a competing scheme." ;
  owl:imports <http://www.w3.org/2004/02/skos/core> ;
  owl:imports <https://ontology.churchcore.ai/cc/cbox/taxonomies> .

# Global extensions (keep as controlled vocabulary; join canonical scheme)

ccgclass:audience_parents a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "parents" ;
  skos:prefLabel "Parents / caregivers" ;
  skos:broader ccclass:audience_parents_families .

ccgclass:audience_marriage a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "marriage" ;
  skos:prefLabel "Marriages / couples" .

ccgclass:audience_singles a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "singles" ;
  skos:prefLabel "Singles" .

ccgclass:audience_grief_support a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "grief_support" ;
  skos:prefLabel "Grief support" .

ccgclass:audience_addiction_recovery a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "addiction_recovery" ;
  skos:prefLabel "Addiction recovery" .

ccgclass:audience_mental_health_support a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "mental_health_support" ;
  skos:prefLabel "Mental health support" .

ccgclass:audience_housing_insecurity a skos:Concept ;
  skos:inScheme ccclass:AudienceScheme ;
  skos:notation "housing_insecurity" ;
  skos:prefLabel "Housing insecurity" .

