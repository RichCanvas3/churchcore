@prefix ccglobal: <https://ontology.churchcore.ai/cc/global#> .
@prefix ccgclass: <https://ontology.churchcore.ai/cc/global/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/global/cbox/audience-segments>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Global C-Box (audience segments)" ;
  rdfs:comment "Ecosystem-scale audience/segment categories for discovery, benchmarking, and targeting. Keep this as controlled vocabulary (SKOS), not classes." ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

ccgclass:AudienceSegmentScheme a skos:ConceptScheme ;
  skos:prefLabel "Audience segments (global)" .

# Life-stage oriented segments (starter set)
ccgclass:audience_kids a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "kids" ; skos:prefLabel "Kids" .
ccgclass:audience_students a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "students" ; skos:prefLabel "Students" .
ccgclass:audience_young_adults a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "young_adults" ; skos:prefLabel "Young adults" .
ccgclass:audience_adults a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "adults" ; skos:prefLabel "Adults" .
ccgclass:audience_seniors a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "seniors" ; skos:prefLabel "Seniors" .

# Family/household oriented segments (starter set)
ccgclass:audience_parents a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "parents" ; skos:prefLabel "Parents / caregivers" .
ccgclass:audience_marriage a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "marriage" ; skos:prefLabel "Marriages / couples" .
ccgclass:audience_singles a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "singles" ; skos:prefLabel "Singles" .

# Community-need oriented segments (starter set; use with care)
ccgclass:audience_grief_support a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "grief_support" ; skos:prefLabel "Grief support" .
ccgclass:audience_addiction_recovery a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "addiction_recovery" ; skos:prefLabel "Addiction recovery" .
ccgclass:audience_mental_health_support a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "mental_health_support" ; skos:prefLabel "Mental health support" .
ccgclass:audience_housing_insecurity a skos:Concept ; skos:inScheme ccgclass:AudienceSegmentScheme ; skos:notation "housing_insecurity" ; skos:prefLabel "Housing insecurity" .

