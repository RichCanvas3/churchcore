@prefix ccgclass: <https://ontology.churchcore.ai/cc/global/class#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontology.churchcore.ai/cc/global/cbox/theology>
  a owl:Ontology ;
  rdfs:label "ChurchCore-Global C-Box (theology)" ;
  rdfs:comment "Starter taxonomy for theological emphases/positions (high-level; extend as needed)." ;
  owl:imports <http://www.w3.org/2004/02/skos/core> .

ccgclass:TheologyScheme a skos:ConceptScheme ; skos:prefLabel "Theology" .
ccgclass:theology_reformed a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "reformed" ; skos:prefLabel "Reformed / Calvinist" .
ccgclass:theology_arminian a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "arminian" ; skos:prefLabel "Arminian / Wesleyan" .
ccgclass:theology_charismatic a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "charismatic" ; skos:prefLabel "Charismatic" .
ccgclass:theology_cessationist a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "cessationist" ; skos:prefLabel "Cessationist" .
ccgclass:theology_dispensational a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "dispensational" ; skos:prefLabel "Dispensational" .
ccgclass:theology_covenantal a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "covenantal" ; skos:prefLabel "Covenantal" .
ccgclass:theology_complementarian a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "complementarian" ; skos:prefLabel "Complementarian" .
ccgclass:theology_egalitarian a skos:Concept ; skos:inScheme ccgclass:TheologyScheme ; skos:notation "egalitarian" ; skos:prefLabel "Egalitarian" .

