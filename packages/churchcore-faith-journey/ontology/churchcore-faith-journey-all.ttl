@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://ontology.churchcore.ai/cc/faith-journey/all>
  a owl:Ontology ;
  rdfs:label "ChurchCore Faith Journey Ontology (all)" ;
  rdfs:comment "Master import file for ChurchCore Faith Journey modules." ;
  owl:imports
    <https://ontology.churchcore.ai/cc/faith-journey/cbox>,
    <https://ontology.churchcore.ai/cc/journey/tbox>,
    <https://ontology.churchcore.ai/cc/state/tbox>,
    <https://ontology.churchcore.ai/cc/cbox/journey> .

