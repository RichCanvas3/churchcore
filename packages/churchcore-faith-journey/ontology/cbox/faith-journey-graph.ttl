  ccjourney:toNode ccfj:journey_gospel_clarity_understand_person_jesus ;
  ccjourney:edgeKind "UNLOCKS" .

ccfj:journey_edge_person_jesus_to_cross_resurrection a ccjourney:JourneyEdge ;
  ccjourney:fromNode ccfj:journey_gospel_clarity_understand_person_jesus ;
  ccjourney:toNode ccfj:journey_gospel_clarity_understand_cross_resurrection ;
  ccjourney:edgeKind "REQUIRES" .

