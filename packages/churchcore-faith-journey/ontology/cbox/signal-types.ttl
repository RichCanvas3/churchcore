ccfjclass:signal_jesus_commitment_status a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "jesus_commitment_status" ; skos:prefLabel "Jesus commitment status" .
ccfjclass:signal_assurance_of_salvation a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "assurance_of_salvation" ; skos:prefLabel "Assurance of salvation level" .
ccfjclass:signal_biblical_authority_commitment a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "biblical_authority_commitment" ; skos:prefLabel "Biblical authority commitment" .
ccfjclass:signal_christian_identity_strength a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "christian_identity_strength" ; skos:prefLabel "Christian identity strength" .
ccfjclass:signal_baptism_status a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "baptism_status" ; skos:prefLabel "Baptism status" .
ccfjclass:signal_public_identification_status a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "public_identification_status" ; skos:prefLabel "Public identification status" .
ccfjclass:signal_testimony_shared_status a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "testimony_shared_status" ; skos:prefLabel "Testimony shared status" .
ccfjclass:signal_public_faith_identification_status a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "public_faith_identification_status" ; skos:prefLabel "Public faith identification status" .
ccfjclass:signal_conversion_testimony_status a skos:Concept ; skos:inScheme ccfjclass:SignalTypeScheme ; skos:notation "conversion_testimony_status" ; skos:prefLabel "Conversion testimony status" .

